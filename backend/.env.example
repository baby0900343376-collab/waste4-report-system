# 複製這個檔案為 .env，並填入你的實際金鑰

# 目前 main.py 預設用 Gemini（import gemini_ocr as ocr_module）
# 到 https://aistudio.google.com/apikey 免費申請
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GEMINI_MODEL=gemini-3.5-flash   # 不填就用預設值（gemini-2.0-flash 已關閉；gemini-2.5-flash 已不開放新用戶使用）

# 如果把 main.py 換回 import claude_ocr as ocr_module，改填這個：
# 到 https://console.anthropic.com/settings/keys 申請
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 資料庫位置，預設用本機 SQLite 檔案。
# 正式上線若要換 PostgreSQL，改成例如：
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=waste4.db
